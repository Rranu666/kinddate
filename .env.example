# ═══════════════════════════════════════════════════════════
# KIND DATE — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control
# ═══════════════════════════════════════════════════════════

# ── SUPABASE ────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key  # Server-side only

# ── OPENAI ──────────────────────────────────────────────────
VITE_OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o

# ── STRIPE ──────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key           # Server-side only
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PLUS_PRICE_ID=price_your-plus-plan-id
STRIPE_PREMIUM_PRICE_ID=price_your-premium-plan-id

# ── PERSONA (ID Verification) ────────────────────────────────
PERSONA_API_KEY=persona_your-api-key
PERSONA_TEMPLATE_ID=your-template-id

# ── TWILIO (SMS OTP) ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── AGORA (Video/Voice Calls) ────────────────────────────────
VITE_AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-certificate

# ── OPENTABLE (Venue Booking) ────────────────────────────────
OPENTABLE_CLIENT_ID=your-opentable-client-id
OPENTABLE_CLIENT_SECRET=your-opentable-secret

# ── APP CONFIG ───────────────────────────────────────────────
VITE_APP_URL=https://kinddate.netlify.app
VITE_APP_NAME=Kind Date
VITE_DEFAULT_CITY=Newport Beach
VITE_DEFAULT_STATE=CA
VITE_DEFAULT_COUNTRY=USA
VITE_COMPANY=KCF LLC
VITE_FOUNDATION=2026 Kindness Community Foundation

# ── NETLIFY (set these in Netlify dashboard) ─────────────────
# Go to: Site Settings → Environment Variables → Add all above
