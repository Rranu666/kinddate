# Supabase
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# App Config
EXPO_PUBLIC_APP_URL=https://kinddate.netlify.app
EXPO_PUBLIC_APP_NAME=KindDate

# Anthropic (for Aria AI)
# Note: Use your Netlify function endpoint, not the API key directly
EXPO_PUBLIC_API_BASE_URL=https://kinddate.netlify.app

# Agora (Video calls)
EXPO_PUBLIC_AGORA_APP_ID=your_agora_app_id

# Stripe
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
