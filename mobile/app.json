{
  "expo": {
    "name": "KindDate",
    "slug": "kinddate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "kinddate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF6F0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kcf.kinddate",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "KindDate uses your camera for profile photos and video dates.",
        "NSPhotoLibraryUsageDescription": "KindDate accesses your photos to set your profile picture.",
        "NSMicrophoneUsageDescription": "KindDate uses your microphone for video and voice dates.",
        "NSLocationWhenInUseUsageDescription": "KindDate uses your location to find nearby matches.",
        "NSFaceIDUsageDescription": "KindDate uses Face ID for quick, secure sign-in.",
        "NSUserNotificationsUsageDescription": "KindDate sends notifications for new matches and messages."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#D05D5A"
      },
      "package": "com.kcf.kinddate",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "KindDate accesses your photos to set your profile picture.",
          "cameraPermission": "KindDate uses your camera for profile photos."
        }
      ],
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "kinddate-mobile-app"
      }
    }
  }
}